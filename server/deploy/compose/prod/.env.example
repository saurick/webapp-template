# 迁移到新服务器时，复制为 .env 并按实际环境调整

# 项目标识（用于容器名等）
PROJECT_SLUG=webapp-template

# 应用镜像
APP_IMAGE=webapp-template-server:dev

# 时区
TZ=Asia/Shanghai
MYSQL_MEM_LIMIT=512m
MYSQL_MEM_RESERVATION=256m
JAEGER_MEM_LIMIT=128m
JAEGER_MEM_RESERVATION=64m
APP_MEM_LIMIT=192m
APP_MEM_RESERVATION=96m
MYSQL_DSN=root:YP*H%k%a7xK1*q@tcp(mysql:3306)/test_database_atlas?charset=utf8mb4&parseTime=True&loc=Local&interpolateParams=true
TRACE_ENDPOINT=jaeger:4318

# 对外端口
MYSQL_PORT=3307
APP_HTTP_PORT=8200
APP_GRPC_PORT=9200

# Jaeger 端口
JAEGER_5775_PORT=15775
JAEGER_6831_PORT=16831
JAEGER_6832_PORT=16832
JAEGER_5778_PORT=15778
JAEGER_UI_PORT=16687
JAEGER_14268_PORT=24268
JAEGER_14250_PORT=24250
JAEGER_9411_PORT=19411
JAEGER_OTLP_GRPC_PORT=14317
JAEGER_OTLP_HTTP_PORT=14318

# MySQL 参数
MYSQL_ROOT_PASSWORD=YP*H%k%a7xK1*q
MYSQL_DATABASE=test_database_atlas
MYSQL_USER=test_user
MYSQL_PASSWORD=2@&0kq%qFafA4d

# 宿主机数据路径
MYSQL_DATA_DIR=/data/webapp-template/mysql/data
MYSQL_CONF_FILE=/data/webapp-template/mysql/conf/mysql8.cnf

# Jaeger span metrics 查询 Prometheus 地址
PROMETHEUS_SERVER_URL=http://host.docker.internal:3004
