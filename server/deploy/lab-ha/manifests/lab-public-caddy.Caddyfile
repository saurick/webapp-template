{
	admin off
}

(common_headers) {
	bind [::]
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}

(http_proxy) {
	import common_headers
	reverse_proxy {args[0]} {
		header_up Host {host}
	}
}

(gitlab_proxy) {
	import common_headers
	reverse_proxy {args[0]} {
		header_up Host {host}
		# GitLab 需要把 session cookie 扩到父域，Portal 才能复用同一浏览器登录态。
		header_down Set-Cookie "$" "; Domain=.saurick.space"
	}
}

lab.saurick.space {
	import http_proxy http://192.168.0.108:30089
}

preview.saurick.space {
	import http_proxy http://192.168.0.108:30091
}

portal.saurick.space {
	import http_proxy http://192.168.0.108:30088
}

observer.saurick.space {
	import http_proxy http://192.168.0.156:30088
}

ddns.saurick.space {
	import http_proxy http://127.0.0.1:9876
}

harbor.saurick.space {
	import http_proxy http://192.168.0.108:30002
}

grafana.saurick.space {
	import http_proxy http://192.168.0.108:30081
