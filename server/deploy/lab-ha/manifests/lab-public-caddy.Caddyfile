app.saurick.space {
	import common_headers
	reverse_proxy http://192.168.0.108:32668 {
		header_up Host app.192.168.0.108.nip.io
	}
}

argocd.saurick.space {
	import common_headers
	reverse_proxy https://192.168.0.108:30443 {
		transport http {
			tls_insecure_skip_verify
		}
		header_up Host {host}
	}
}
